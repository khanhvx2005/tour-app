mixin select-tree(categoryList , level=0 , parentId = "")
    each item in categoryList
        - const prefix = Array(level + 1).join('-- ')

        option(value=item.id selected= (item.id == parentId ? true: false)) #{prefix}#{item.name}
            if item.children && item.children.length > 0 
                +select-tree(item.children , level + 1)
