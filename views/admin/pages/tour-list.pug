extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/filter-created-by.pug
include ../mixins/select-tree.pug
include ../mixins/pagination.pug

block main
  if (permissions.includes("tour_view"))

    +alert_success("5000")

    h1.box-title Quản lý tour

    //- Section 4
    .section-4
      .inner-wrap
        .inner-item.inner-label
          <i class="fa-solid fa-filter"></i> Bộ lọc
        .inner-item
          include ../partials/filter-status.pug
        .inner-item
          +filter-created-by(accountAdminList)
        .inner-item.inner-date
          include ../partials/filter-date.pug
        .inner-item
          select(filter-category)
            option(value="") Danh mục
            +select-tree(categoryList)
        .inner-item
          include ../partials/filter-price.pug
        .inner-item.inner-reset(filter-reset)
          <i class="fa-solid fa-rotate-left"></i> Xóa bộ lọc
    //- End Section 4

    //- Section 5
    .section-5
      .inner-wrap
        if (permissions.includes("tour_edit"))

          include ../partials/change-multi.pug
        .inner-search
          <i class="fa-solid fa-magnifying-glass"></i>
          input(type="text" placeholder="Tìm kiếm" search-input)
        if (permissions.includes("tour_create"))

          .inner-button-create
            a(href=`/${pathAdmin}/tour/create`) + Tạo mới
        if (permissions.includes("tour_trash"))

          .inner-button-trash
            a(href=`/${pathAdmin}/tour/trash`) Thùng rác
    //- End Section 5

    //- Section 6
    .section-6
      .table-2
        table
          thead
            tr
              th(class="inner-center")
                input(type="checkbox" class="inner-check" check-all)
              th Tên tour
              th Ảnh đại diện
              th(style="width: 130px") Giá
              th Còn lại
              th(class="inner-center") Vị trí
              th(class="inner-center") Trạng thái
              th Tạo bởi
              th Cập nhật bởi
              th Hành động
          tbody
            each item in tourList
              tr
                td(class="inner-center")
                  input(type="checkbox" class="inner-check" check-item = item.id)
                td #{item.name}
                td
                  img(src=item.avatar class="inner-avatar" alt = item.name)
                td
                  div NL: #{item.priceNewAdult.toLocaleString('vi-VN')} <sup>đ</sup>
                  div TE: #{item.priceNewChildren.toLocaleString('vi-VN')} <sup>đ</sup> 
                  div EB: #{item.priceNewBaby.toLocaleString('vi-VN')} <sup>đ</sup>
                td
                  div NL: #{item.stockAdult}
                  div TE: #{item.stockChildren}
                  div EB: #{item.stockBaby}
                td(class="inner-center") #{item.position}
                td(class="inner-center")
                  if(item.status == "active")
                    .badge.badge-green Hoạt động
                  else 
                    .badge.badge-red Tạm dừng   
                td
                  div #{item.createdByFullname}
                  div.inner-time #{item.createdAtFormat}
                td
                  div #{item.updatedByFullname}
                  div.inner-time #{item.updatedAtFormat}
                td
                  .inner-buttons
                    if (permissions.includes("tour_edit"))

                      a(
                        class="inner-edit"
                        href = `/${pathAdmin}/tour/edit/${item.id}`
                      ) <i class="fa-regular fa-pen-to-square"></i>
                    if (permissions.includes("tour_delete"))

                      button(
                        class="inner-delete"  
                        data-api=`/${pathAdmin}/tour/delete/${item.id}`
                        button-delete                  
                      ) <i class="fa-regular fa-trash-can"></i>
    //- End Section 6

    //- Section 7
    +pagination(pagination)
        
    //- End Section 7